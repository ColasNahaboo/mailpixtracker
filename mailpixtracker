################################# Backoffice: non-GUI functions

################################# NEW Tracker ID creation, redirects to id page

create-id(){
    local name="$1" note="$2" id idpass
    # find next available id
    mkdir -p "$data"
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    id=$(ls -1 "$data" | grep -oP '^[[:digit:]]+(?=-.*[.]meta$)' | sort -nr | head -1)
    ((id++))
    idpass="$id-"$(random_string $passlen)
    true >"$data/$idpass.log"
    metas=([name]=$(html_escape "$name") [note]=$(html_escape "$note"))
    meta-write-raw "$data/$idpass.meta"
    redirect "?mode=logs&id=$id&info=new_tracker_created"
}

################################# META modification, then redirect to log page

save-id(){
    local id="$1" name="$2" note="$3" meta metas
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    metafile=("$data/$id-"*.meta); meta="${metafile[0]}"
    [[ -e "$meta" ]] || redirect "?id=$id&info=error:_edit_unknown_id:_$id"
    meta-read-raw "$meta"
    metas[name]=$(html_escape "$name")
    metas[note]=$(html_escape "$note")
    meta-write-raw "$meta"
    redirect "?mode=logs&id=$id&info=tracker_info_edited"
}

################################# New guest

create-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" gpass
    $isadmin || redirect "$url?info=error:_not_admin" # we must be the admin
    metas=([note]="$FORM_note")
    [[ -n "$FORM_isadmin" ]] && metas[admin]=true || metas[admin]=false
    [[ -z "$gid" ]] && redirect "?mode=admin&info=error:_invalid_guest_name"
    # shellcheck disable=SC2010,SC2012,SC2035   # Allow ls instead of find
    gpass=$(ls -1 *"~$gid" | grep -v '[*]' | grep -oPm1 -- '~\K[[:alnum:]]+')
    [[ -n "$gpass" ]] && redirect "?mode=admin&info=error:_existing_guest_name"
    gpass=$(random_string $((passlen + 2)) )
    ln -sf "$adminpass" "$gpass~$gid"
    mkdir "$data/~$gid"
    meta-write-raw "$data/~$gid"/meta
    redirect "?mode=admin&info=guest_${gid}_created"
}

################################# Edit guest

save-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" name="$2" note="$3" admin="$4"
    local meta="$data/~$gid/meta"
    [[ -e "$meta" ]] || redirect "?mode=admin&info=error:_try_to_save_unknown_guest_id:_$gid"
    meta-read-raw "$meta"
    metas[note]="$note"
    metas[admin]="$admin"
    meta-write-raw "$meta"
    redirect "?mode=admin&info=guest_${gid}_saved"
}

################################# Delete guest

del-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" name="$2" note="$3" admin="$4"
    local meta="$data/~$gid/meta" trash="$data/trashguests"
    [[ -e "$meta" ]] || redirect "?mode=admin&info=error:_try_to_delete_unknown_guest_id:_$gid"
    mkdir -p "$trash"/{cgi,data}
    rm -rf "$trash/cgi/"[a-zA-Z0-9]*"~$gid" "$trash/data/~$gid"
    mv [a-zA-Z0-9]*"~$gid" "$trash/cgi"
    mv "$data/~$gid" "$trash/data"
    redirect "?mode=admin&info=guest_${gid}_deleted"
}

################################# Delete id

del-id(){
    local id="${1//[^[:digit:]]/}" gid="${2//[^-_.[:alnum:]]/}"
    local meta metafile=("$data"/"$id"-*.meta) trash="$data/trash"
    meta="${metafile[0]}"
    [[ -e "$meta" ]] || redirect "?info=error:_try_to_delete_unknown_tracker_id:_$id"
    mkdir -p "$trash"
    mv "$data/$id-"* "$trash"
    redirect "?mode=trackers&info=tracker_${id}_deleted"
}

################################# Misc utils

# sets the color global var to the color of the row, caches in rowkeys[ip]
rowkey=0                        # static index to current rowscol[] to use
rowcolor(){
    local ip="$1"
    color="${rowkeys[$1]}"
    if [[ -n "$color" ]]; then  # cached
        return
    elif ((rowkey > rowscolmax)); then # overflow, just loop avoiding firt one
        color="${rowscol[1]}"
        rowkey=2
        rowkeys[$ip]="$color"
    else                        # allocate next color from the predefined ones
        color="${rowscol[$rowkey]}"
        ((rowkey++))
        rowkeys[$ip]="$color"
    fi
}
# static vars for rowcolor()
# a map[ipadress] = color
declare -A rowkeys
# To maximize perceptual spacing, I used golden-angle hue sampling
# (137.508° steps), a well-known approximation of greedy max-min spacing
# to allow distinct colors to distinct IPs
rowscol[0]='#f7f7f7'
rowscol[1]='hsl( 92.5, 60%, 95%)'
rowscol[2]='hsl(315.0, 60%, 95%)'
rowscol[3]='hsl(177.5, 60%, 95%)'
rowscol[4]='hsl( 40.0, 60%, 95%)'
rowscol[5]='hsl(262.5, 60%, 95%)'
rowscol[6]='hsl(125.0, 60%, 95%)'
rowscol[7]='hsl(347.5, 60%, 95%)'
rowscol[8]='hsl(210.0, 60%, 95%)'
rowscol[9]='hsl( 72.5, 60%, 95%)'
rowscol[10]='hsl(295.0, 60%, 95%)'
rowscol[11]='hsl(157.5, 60%, 95%)'
rowscol[12]='hsl( 20.0, 60%, 95%)'
rowscol[13]='hsl(242.5, 60%, 95%)'
rowscol[14]='hsl(105.0, 60%, 95%)'
rowscol[15]='hsl(327.5, 60%, 95%)'
rowscol[16]='hsl(190.0, 60%, 95%)'
rowscol[17]='hsl( 52.5, 60%, 95%)'
rowscol[18]='hsl(275.0, 60%, 95%)'
rowscol[19]='hsl(137.5, 60%, 95%)'
rowscol[20]='hsl(  0, 60%, 95%)'
rowscolxtra='#eee'
