export VERSION=3.0.0
export PROGNAME='Mail Pix Tracker'
export source='https://github.com/ColasNahaboo/mailpixtracker'
export copyright='(c)2026 Colas Nahaboo, MIT License'
export PPLOG=/tmp/mpt.log       # can be used for debugging with PP functions

