# from a 32x32 png image with tranparent bg, via: base64 -w 0 imagefile.png
logo=''

htmail_logo=''

editicon=''

###################### Common

ROOT_URL="$REQUEST_SCHEME://$HTTP_HOST"
adminpass="${SCRIPT_NAME##*/}"   # adminpass or guestpass~guestid
url="$ROOT_URL$SCRIPT_NAME"      # its URL
urlp="$ROOT_URL/_"               # URL of pixel logger mini-script
data=$(realpath '../data')       # metadata, logs, caches, guest ids...
nl=$'\n'; tab=$'\t'; sp='&nbsp;' # some useful constants
# true ISO is YYYY-MM-DDTHH:MN:SS, but we use more readbale: YYYY-MM-DD.HHhMN,SS
export dateformat='%Y-%m-%d.%Hh%M,%S' # format of dates in logs.
passlen=8                # length of the random "passwords", 10^14 combinations

# shellcheck disable=SC1091 # Ok to not check included file syntax
. cgibashopts
err() { echo "***ERROR: $*" >&2; exit 1; }
version="<p class=version><a href='$source'>${source##*/}</a> v$VERSION, $copyright</p>"
if [[ $SCRIPT_NAME =~ /([[:alnum:]]+)([~][-_.[:alnum:]]+)$ ]]; then
    gid="/${BASH_REMATCH[2]}"       # guest id, in the form "/~guestid"
    isadmin=false
    data="$data$gid"
    urlp="$urlp$gid"
    # shellcheck disable=SC1091
    [[ -e "$data/meta" ]] && . "$data/meta"
    isguestadmin=false
    [[ "${metas[admin]}" == true ]] && isguestadmin=true || isguestadmin=false
    adminpass=$(readlink "${SCRIPT_NAME##*/}")
else
    gid=                            # admin
    isadmin=true
fi

# args: subtitle comma-separated-tabs (active one postfixed by !)
header(){
    local title="${PROGNAME}${1:+: }${1}" tabs=",$2," guestlabel titlelabel
    if ! $isadmin; then
        guestlabel=" <span class=guest>[${gid#*~}]</span>"
        titlelabel=" [${gid#*~}]"
    fi
    echo "Content-Type: text/html$nl$nl<html><head>
<link rel=icon type='image/png' sizes='32x32' href='data:image/png;base64,$logo'>
<style>$style</style><title>$title$titlelabel</title>
</head><body><header class='main-header'>
<div class='brand'><a href='$url'><img class=logo src='data:image/png;base64,$logo'> $title$guestlabel</a></div><nav class='nav-tabs'>"
    [[ $tabs =~ ,trackers(!)?, ]] &&
        echo "<a href='$url' class='tab${BASH_REMATCH[1]:+ active}'>Trackers</a>"
    [[ $tabs =~ ,logs(!)?, ]] &&
        echo "<a href='$url?mode=logs&id=$id' class='tab${BASH_REMATCH[1]:+ active}'>Tracker #$id</a>"
    if [[ $tabs =~ ,admin(!)?, ]]; then
        if $isadmin; then
            echo "<a href='$url?mode=admin' class='tab${BASH_REMATCH[1]:+ active}'>Admin</a>"
        elif "$isguestadmin"; then
            echo "<a href='$adminpass?mode=admin' class='tab${BASH_REMATCH[1]:+ active}'>Admin</a>"
        fi
    fi
    # shellcheck disable=SC2154        # FORM_xxx are defined by cgibashopts
    [[ $tabs =~ ,guest(!)?, ]] &&
        echo "<a href='$url' class='tab${BASH_REMATCH[1]:+ active}'>Account ${FORM_gid}</a>"
    echo "</nav></header>"
}
is-active(){
    [[ "$1" == "$2" ]] && echo " active"
}
footer(){
    echo "<hr><div class=minicontainer>$version</div></body></html>"
}
info(){
    # shellcheck disable=SC2154 # FORM_xxx are defined by cgibashopts
    local mess="$FORM_info" class=info
    [[ -n "$mess" ]] || return
    [[ $mess =~ ^([[:alnum:]]+): ]] && class="$class ${BASH_REMATCH[1]}"
    [[ "$class" == info ]] && class="$class ok"
    mess="${mess//_/ }"
    echo "<div class='$class'>${mess^}</div>"
}
redirect(){
    echo "Location:$1$nl"
    exit 0
}

################################# Frontoffice: GUI functions

################################# MAIN (trackers) mode

main(){
    local tabs="$1" idpass id idpass idname last # idpass=NN-nnpass
    header '' "$tabs"
    info
    # Section: list existing trackers
    if [[ -d "$data" ]]; then
        echo "<div class=container>Existing trackers:<ul>"
        # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
        for meta in "$data"/[0-9]*.meta; do
            [[ -e "$meta" ]] || continue
            idpass="${meta##*/}"; idpass="${idpass%.*}"
            id="${idpass%%-*}"
            last=$(tail -1 "${meta%.*}.log" 2>/dev/null | cut -f 1 -d $'\t')
            meta-read-raw "$meta"
            idname=
            [[ -n "${metas[name]}" ]] && idname=" <b>${metas[name]}</b>"
            echo -n "<li><a href='?mode=logs&id=$id' title='See logs of #$id'>#$id</a>$sp$sp$sp$idname"
            if [[ -n "$last" ]]; then
                echo ", last log on $last"
            else
                echo " <span class=guest>(no access logs yet)</span>"
            fi                  
        done
        echo "</ul></div>"
    fi
    # Section: create a new tracker
    echo "<form method=POST enctype='multipart/form-data' class=container>
          Create a new tracker to insert in emails:<p>
          <input type=hidden name=newid value=true>
          <table>
          <tr><td>Name:<td><input type=text name=name size=48 value=''>
          <tr><td>Note:<td><textarea name=note rows=3 cols=64></textarea>
          <tr><td colspan=2><input class='btn' type='submit' value='Create'>
          </table></form>"
    footer
}

################################# Logs of ID, and other info

main-logs(){
    local id="$1" tabs="$2" meta metafile notenl notelines idpass
    metafile=("$data/$id-"*.meta); meta="${metafile[0]}"
    [[ -e "$meta" ]] || redirect "?id=$id&info=error:_logs_unknown_id:_$id"
    idpass="${meta##*/}"; idpass="${idpass%.*}"
    meta-read-raw "$meta"
    notenl="${metas[note]//[^$tab]/}" # keep only the newlines
    notelines=$((${#notenl} + 2))   # to know the number of lines for editing

    header "Tracker #$id" "$tabs"
    info
    echo "<div class=container>
<p>To insert a tracker of ID # $id in an email, insert the below code in gmail via <a href='https://addons.mozilla.org/en-US/firefox/addon/htmail/'>HTMail</a><br />(icon:
       <img src='data:image/png;base64,$htmail_logo' style='vertical-align:bottom'> at the bottom right of the mail compose window)
        <p>
        <code class=mptcode>&lt;img src='$urlp/$idpass' width='1' height='1'&gt;</code>
        <p>
        <h2>Info for #$id</h2>
        <form action='?editid=$id' method=POST>
        <input type=hidden name=id value='$id'>
        <table class=mptlog><tr><th>Name:<td><input type=text name=name size=64 value='${metas[name]}'>
        <tr><th>Notes:<td><textarea name=note rows=$notelines cols=64>${metas[note]//$tab/$nl}</textarea>
        <tr style='text-align:left'><td><td><input type=submit value='Modify'>
        </table></form>
        <h2>Access logs</h2>"
    if [[ -s "$data/$idpass.log" ]]; then
        local line date hip host agent
        echo "<table class=mptlog>
        <tr><th>Date<th>IP address<th>Hostname<th>User Agent"
        # init first IP (ours) to grey color
        rowcolor "$(head -1 "$data/$idpass.log" | cut -d $'\t' -f 2)"
	while read -r line; do
            date=
            if [[ $line =~ ^([^$tab]+)$tab([^$tab]+)$tab([^$tab]*)$tab(.*) ]]; then
                date="${BASH_REMATCH[1]}"
                hip="${BASH_REMATCH[2]}"
                host="${BASH_REMATCH[3]}"
                agent="${BASH_REMATCH[4]}"
            fi
            if [[ -n "$date" ]]; then
                rowcolor "$hip"  # sets color
                echo "<tr style='background-color:$color'><td><b>$date</b><td>$hip<td><i>$host</i><td class=useragent>$agent</small></tr>"
            else                # unknown format
                echo "<tr style='background-color:$rowscolxtra'><td colspan=4>${line}"
            fi
        done < <(tac "$data/$idpass.log")
        echo "</table>"
    else
	echo "No access logs yet"
    fi
    echo "</div>"
    echo "<form method=POST enctype='multipart/form-data' class=container>
          You can also delete this tracker and log, if you are <b>sure</b> you have not yet used it:<p>
          <input type=hidden name=delid value='$id'>
          <input type=hidden name=gid value='${gid#/~}'>
          <input class='btn' type='submit' value='Delete Tracker #$id'>
          </table></form>"
    footer
}

################################# Admin

main-admin(){
    local tabs="$1" i gid gpass gurl gnote nguests=0 admin
    $isadmin || redirect "$url?info=error:_not_admin"
    header '' "$tabs"
    info
    echo "<div class=container>Guest accounts:<ul>"
    for i in *'~'*; do
        [[ $i =~ ^([[:alnum:]]+)[~]([-_.[:alnum:]]+)$ ]] || continue
        gid="${BASH_REMATCH[2]}"
        gpass="${BASH_REMATCH[1]}"
        gurl="https://$SERVER_NAME${SCRIPT_NAME%/*}/$gpass~$gid"
        [[ -e "$data/~$gid/meta" ]] || true >"$data/~$gid/meta"
        meta-read-raw "$data/~$gid/meta"
        gnote="${metas[note]}"
        [[ -n "${metas[admin]}" ]] && admin=' [admin]'
        echo "<li><a href='?mode=editguest&gid=$gid' title='Edit info of $gid'><img src='data:image/png;base64,$editicon' class=logo></a> <b>${gid}$admin</b>${gnote:+ (}$gnote${gnote:+)}: $sp$sp$sp <a href='$gurl' title='\"log in\" as $gid'><tt>$gurl</tt></a>"
        ((nguests++))
    done
    ((nguests == 0)) && echo "<i>...none...</i>"
    echo "</ul></div>"
    # Section: create a new guest
    echo "<div container>
          <form method=POST enctype='multipart/form-data' class=container>
          Create a new guest account:<p>
          <table>
          <tr><td>Name:<td><input type=text name=newguest size=12 value=''>
          <td><i>short id: letters, numbers, hyphen, dot, underscore</i>
          <tr><td>Note:<td colspan=2><input type=text name=note size=64 value=''>$sp$sp$sp<i>Description</i>
          <tr><td><label for=isadmin style='cursor: pointer;'>Is Admin:</label>
          <td><input type=checkbox id=isadmin name=isadmin value=yes>
          <td><i>Non-admins have no way to access the admin account. Admin guests have a tab to become the admin</i>
          <tr><td colspan=3><input class='btn' type='submit' value='Create a new guest account'>
          </table></form></div>"
    footer
}
################################# Edit Guest GUI

main-guest(){
    local tabs="$1" i gid="$FORM_gid"
    $isadmin || redirect "$url?info=error:_not_admin"
    local meta="$data/~$gid/meta" isadmin
    [[ -e "$meta" ]] || redirect "?mode=admin&info=error:_edit_unknown_guest_id:_$gid"
    header '' "$tabs"
    info
    meta-read-raw "$meta"
    [[ "${metas[admin]}" == true ]] && isadmin=checked
    # Section: Edit guest
    echo "<form method=POST enctype='multipart/form-data' class=container>
          Edit guest account $gid:<p>
          <input type=hidden name=savegid value='$gid'>
          <table>
          <tr><td>Note:<td colspan=2><input type=text name=note size=64 value='${metas[note]}'>
          <tr><td><label for=isadmin style='cursor: pointer;'>Is Admin:</label>
          <td><input type=checkbox id=isadmin name=isadmin value=yes $isadmin>
          <td><i>(has a tab to go to the admin account)</i>
          <tr><td colspan=3><input class='btn' type='submit' value='Save'>
          </table></form>"
    echo "<form method=POST enctype='multipart/form-data' class=container>
          Or delete guest account $gid:<p>
          <input type=hidden name=delgid value='$gid'>
          <input class='btn' type='submit' value='Delete'>
          </table></form>"
