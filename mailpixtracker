# from a 32x32 png image with tranparent bg, via: base64 -w 0 imagefile.png
logo=''

htmail_logo=''

###################### Common

ROOT_URL="$REQUEST_SCHEME://$HTTP_HOST"
scriptname="${SCRIPT_NAME##*/}" # adminpass or guestpass~guestid
url="$ROOT_URL$SCRIPT_NAME"     # its URL
urlp="$ROOT_URL/_"              # URL of pixel logger mini-script
data=$(realpath '../data')      # metadata, logs, caches, guest ids...
nl=$'\n';  tab=$'\t'            # some useful constants
# true ISO is YYYY-MM-DDTHH:MN:SS, but we use more readbale: YYYY-MM-DD.HHhMN,SS
export dateformat='%Y-%m-%d.%Hh%M,%S' # format of dates in logs.
passlen=8                # length of the random "passwords", 10^14 combinations

# shellcheck disable=SC1091 # Ok to not check included file syntax
. cgibashopts
err() { echo "***ERROR: $*" >&2; exit 1; }
version="<p class=version><a href='$source'>${source##*/}</a> v$VERSION, $copyright</p>"
if [[ $SCRIPT_NAME =~ /([[:alnum:]]+)([~][-_.[:alnum:]]+)$ ]]; then
    gid="/${BASH_REMATCH[2]}"       # guest id, in the form "/~guestid"
    isadmin=false
    data="$data$gid"
    urlp="$urlp$gid"
else
    gid=                            # admin
    isadmin=true
fi

# args: subtitle comma-separated-tabs (active one postfixed by !)
header(){
    local title="${PROGNAME}${1:+: }${1}" tabs=",$2," guestlabel titlelabel
    if ! $isadmin; then
        guestlabel=" <span class=guest>[${gid#*~}]</span>"
        titlelabel=" [${gid#*~}]"
    fi
    echo "Content-Type: text/html$nl$nl<html><head>
<link rel=icon type='image/png' sizes='32x32' href='data:image/png;base64,$logo'>
<style>$style</style><title>$title$titlelabel</title>
</head><body><header class='main-header'>
<div class='brand'><a href='$url'><img class=logo src='data:image/png;base64,$logo'> $title$guestlabel</a></div><nav class='nav-tabs'>"
    [[ $tabs =~ ,trackers(!)?, ]] &&
        echo "<a href='$url' class='tab${BASH_REMATCH[1]:+ active}'>Trackers</a>"
    [[ $tabs =~ ,logs(!)?, ]] &&
        echo "<a href='$url?mode=logs&id=$id' class='tab${BASH_REMATCH[1]:+ active}'>Tracker #$id</a>"
    [[ $tabs =~ ,admin(!)?, ]] && $isadmin &&
        echo "<a href='$url?mode=admin' class='tab${BASH_REMATCH[1]:+ active}'>Admin</a>"
    echo "</nav></header>"
}
is-active(){
    [[ "$1" == "$2" ]] && echo " active"
}
footer(){
    echo "<hr><div class=minicontainer>$version</div></body></html>"
}

################################# Frontoffice: GUI functions

################################# MAIN mode

main(){
    local tabs="$1" idpass id pass idname last # idpass=NN-nnpass
    header '' "$tabs"
    # Section: create a new tracker
    echo "<div class=minicontainer>"
    echo "<form method=POST enctype='multipart/form-data' class=container>
          <ul><li>Create a new tracker to insert in emails named:
          <input type=text name=newid size=48 value=''>
          <input type=submit value='Create'></form>"
    # Section: list existing trackers
    if [[ -d "$data" ]]; then
        echo "<li>Show logs for existing trackers:<ul>"
        # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
        while read -r idpass; do
            id="${idpass%%-*}"
            pass="${idpass#*-}"
            if [[ -e "$data/$idpass" ]]; then
                last=$(tail -1 "$data/$idpass.log" 2>/dev/null | cut -f 1 -d ' ')
                idname=$(grep -soPm1 '^name +\K.*' "$data/$idpass")
                [[ -n "$idname" ]] && idname=" <b>$idname</b>"
                echo "<li><a href='?mode=logs&id=$id'>#$id</a>$idname"
                if [[ -n "$last" ]]; then
                    echo ", last log on $last</li>"
                else
                    echo " <span class=guest>(no access logs yet)</span>"
                fi                  
            fi
        done < <(ls -1 "$data" | grep -oP '^[[:digit:]]+-[[:alnum:]]+$' | sort -nr)
        echo "</ul></form>"
    fi
    echo "</ul>"
    footer
}

################################# Logs of ID, and other info

main-logs(){
    local id="$1" tabs="$2" pass idname idnoteq idnote idnotenls idnotel
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    pass=$(ls -1 "$data/$id-"* | grep -oPm1 -- '-\K[[:alnum:]]+')
    idname=$(grep -soPm1 '^name +\K.*' "$data/$id-$pass")
    idnoteq=$(grep -soPm1 '^note +\K.*' "$data/$id-$pass")
    idnote="${idnoteq//$tab/$nl}"
    idnotenls="${idnoteq//[^$tab]/}" # keep only the newlines
    idnotel=$((${#idnotenls} + 2))   # to know the number of lines for editing

    header "Tracker #$id" "$tabs"
    echo "<div class=container>
<p>To insert a tracker of ID # $id in an email, insert the below code in gmail via <a href='https://addons.mozilla.org/en-US/firefox/addon/htmail/'>HTMail</a><br />(icon:
       <img src='data:image/png;base64,$htmail_logo' style='vertical-align:bottom'> at the bottom right of the mail compose window)
        <p>
        <code class=mptcode>&lt;img src='$urlp/$id-$pass' width='1' height='1'&gt;</code>
        <p>
        <h2>Info for #$id</h2>
        <form action='?editid=$id' method=POST>
        <input type=hidden name=id value='$id'>
        <table class=mptlog><tr><th>Name:<td><input type=text name=name size=64 value='$idname'>
        <tr><th>Notes:<td><textarea name=note rows=$idnotel cols=71>$idnote</textarea>
        <tr style='text-align:left'><td><td><input type=submit value='Modify'>
        </table></form>
        <h2>Access logs</h2>"
    if [[ -s "$data/$id-$pass.log" ]]; then
        echo "<table class=mptlog>
        <tr><th>Date<th>IP address<th>Hostname<th>User Agent"
        # init first IP (ours) to grey color
        rowcolor "$(head -1 "$data/$id-$pass.log" | cut -d $'\t' -f 2)"
	while read -r line; do
            date=
            if [[ $line =~ ^([^$tab]+)$tab([^$tab]+)$tab([^$tab]*)$tab(.*) ]]; then
                date="${BASH_REMATCH[1]}"
                ip="${BASH_REMATCH[2]}"
                host="${BASH_REMATCH[3]}"
                agent="${BASH_REMATCH[4]}"
            fi
            if [[ -n "$date" ]]; then
                rowcolor "$ip"  # sets color
                echo "<tr style='background-color:$color'><td><b>$date</b><td>$ip<td><i>$host</i><td class=useragent>$agent</small></tr>"
            else                # unknown format
                echo "<tr style='background-color:$rowscolxtra'><td colspan=4>${line}"
            fi
        done < <(tac "$data/$id-$pass.log")
        echo "</table>"
    else
	echo "No access logs yet"
    fi
    echo "</div>"
    footer
}

################################# Admin

main-admin(){
    local tabs="$1" i gid gpass gurl nguests=0
    $isadmin || { echo "Location:$url$nl"; exit 0;}
    header '' "$tabs"
    echo "<div class=container>Guest accounts:<uL>"
    for i in *'~'*; do
        [[ $i =~ ^([[:alnum:]]+)[~]([-_.[:alnum:]]+)$ ]] || continue
        gid="${BASH_REMATCH[2]}"
        gpass="${BASH_REMATCH[1]}"
        gurl="https://$SERVER_NAME${SCRIPT_NAME%/*}/$gpass~$gid"
        echo "<li><b>${gid}</b>: <a href='$gurl'><tt>$gurl</tt></a>"
        ((nguests++))
    done
    ((nguests == 0)) && echo "<i>...none...</i>"
    echo "</ul></div>"
    echo "<form id='create-guest' method='POST' enctype='multipart/form-data' class=container>
       <input type=text size=12 name=newguest>
       <input class='btn' type='submit' value='Create new guest'>
       <i>(short id: letters, numbers, hyphen, dot, underscore)</i>
    </form>"   
    footer
}

################################# Backoffice: non-GUI functions

################################# NEW Tracker ID creation, redirects to id page

create-id(){
    local name="$1" id pass qname
    # find next available id
    mkdir -p "$data"
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    id=$(ls -1 "$data" | grep -oP '^[[:digit:]]+' | sort -nr | head -1)
    pass=$(random_string $passlen)
    ((id++))
    true >"$data/$id-$pass"
    true >"$data/$id-$pass.log"
    if [[ -n "$name" ]]; then
        qname=$(html_escape "$name")
        echo "name $qname" >>"$data/$id-$pass"
    fi
    echo "Location:?mode=logs&id=$id$nl"
    exit 0
}

################################# META modification, then redirect to log page

edit-id(){
    local id="$1" name="$2" note="$3" pass qname idname idnoteq idnote rest meta
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    pass=$(ls -1 "$data/$id-"* | grep -oPm1 -- '-\K[[:alnum:]]+')
    meta="$data/$id-$pass"
    idname=$(grep -soPm1 '^name +\K.*' "$meta")
    idnoteq=$(grep -soPm1 '^note +\K.*' "$meta")
    idnote="${idnoteq//$tab/$nl}"
    rest=$(grep -vsE  '^(name|note) ' "$meta")
    : >"$meta"
    if [[ -n "$name" ]]; then
        qname=$(html_escape "$name")
        echo "name $qname" >>"$meta"
    fi
    if [[ -n "$note" ]]; then
        qnote=$(html_escape "$note")
        echo "note $qnote" >>"$meta"
    fi
    [[ -n "$rest" ]] && echo "$rest" >>"$meta"
    echo "Location:?mode=logs&id=$id$nl"
}

################################# New guest

create-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" gpass
    [[ -z "$gid" ]] && { echo "Location:?mode=admin$nl"; exit 0;} # error
    # shellcheck disable=SC2010,SC2012,SC2035   # Allow ls instead of find
    gpass=$(ls -1 *"~$gid" | grep -v '[*]' | grep -oPm1 -- '~\K[[:alnum:]]+')
    [[ -n "$gpass" ]] && { echo "Location:?mode=admin$nl"; exit 0;} # error
    gpass=$(random_string $((passlen + 2)) )
    ln -sf "$scriptname" "$gpass~$gid"
    mkdir "$data/~$gid"
    echo "Location:?mode=admin$nl"
}

################################# Misc utils

# sets the color global var to the color of the row, caches in rowkeys[ip]
rowkey=0                        # static index to current rowscol[] to use
rowcolor(){
    local ip="$1"
    color="${rowkeys[$1]}"
    if [[ -n "$color" ]]; then  # cached
        return
    elif ((rowkey > rowscolmax)); then # overflow, just loop avoiding firt one
        color="${rowscol[1]}"
        rowkey=2
        rowkeys[$ip]="$color"
    else                        # allocate next color from the predefined ones
        color="${rowscol[$rowkey]}"
        ((rowkey++))
        rowkeys[$ip]="$color"
    fi
}
# static vars for rowcolor()
# a map[ipadress] = color
declare -A rowkeys
# To maximize perceptual spacing, I used golden-angle hue sampling
# (137.508° steps), a well-known approximation of greedy max-min spacing
# to allow distinct colors to distinct IPs
rowscol[0]='#f7f7f7'
rowscol[1]='hsl( 92.5, 60%, 95%)'
rowscol[2]='hsl(315.0, 60%, 95%)'
